# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web Search — Brave Search API (free: 2000 queries/month)
# Get your key at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# News — NewsAPI (free: 100 requests/day)
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# News — GNews API (optional, free: 100 requests/day)
# Get your key at: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here
